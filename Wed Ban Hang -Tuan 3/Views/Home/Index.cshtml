@{
    ViewData["Title"] = "Trang chủ";
}

<div class="container">

    <!-- Banner -->
    <div class="p-5 mb-4 bg-light rounded-3">
        <div class="container-fluid py-5 text-center">
            <h1 class="display-5 fw-bold">Chào mừng đến Web Bán Hàng Toàn Năng</h1>
            <p class="fs-4">Chỉ Cần Là Thứ Bạn Cần Chúng Tôi Đều Không Có</p>
            <a class="btn btn-primary btn-lg" href="/Product">Xem sản phẩm</a>
        </div>
    </div>

    <!-- Tiêu đề -->
    <h2 class="text-center mb-4">Sản phẩm nổi bật</h2>

    <div class="row">

        <!-- Product 1 -->
        <div class="col-md-4">
            <div class="card shadow">
                <img src="https://via.placeholder.com/300x200" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Laptop Gaming</h5>
                    <p class="card-text">Laptop hiệu năng cao dành cho game thủ.</p>
                    <a href="/Product" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>

        <!-- Product 2 -->
        <div class="col-md-4">
            <div class="card shadow">
                <img src="https://via.placeholder.com/300x200" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Điện thoại</h5>
                    <p class="card-text">Smartphone mới nhất với nhiều tính năng.</p>
                    <a href="/Product" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>

        <!-- Product 3 -->
        <div class="col-md-4">
            <div class="card shadow">
                <img src="https://via.placeholder.com/300x200" class="card-img-top">
                <div class="card-body">
                    <h5 class="card-title">Tai nghe</h5>
                    <p class="card-text">Âm thanh chất lượng cao.</p>
                    <a href="/Product" class="btn btn-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>

    </div>

</div>