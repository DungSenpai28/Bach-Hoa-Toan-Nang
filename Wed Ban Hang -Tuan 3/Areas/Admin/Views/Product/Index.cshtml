@model IEnumerable<Wed_Ban_Hang__Tuan_3.Models.Product>
<h2>Danh sách sản phẩm (Admin)</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Giá</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
            </tr>
        }
    </tbody>

</table>